{
  "lexicon": 1,
  "id": "app.bsky.feed.post",
  "defs": {
    "main": {
      "type": "record",
      "record": {
        "type": "object",
        "required": ["text", "createdAt"],
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 3000,
            "maxGraphemes": 300
          },
          "createdAt": {
            "type": "string"
          },
          "langs": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 16
            }
          },
          "reply": {
            "type": "object",
            "required": ["root", "parent"],
            "properties": {
              "root": {
                "type": "object",
                "required": ["uri", "cid"],
                "properties": {
                  "uri": { "type": "string" },
                  "cid": { "type": "string" }
                }
              },
              "parent": {
                "type": "object",
                "required": ["uri", "cid"],
                "properties": {
                  "uri": { "type": "string" },
                  "cid": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
