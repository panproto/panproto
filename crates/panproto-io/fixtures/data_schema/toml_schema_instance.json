{
  "package": {
    "name": "panproto-io",
    "version": "0.2.0",
    "edition": "2024",
    "authors": ["Aaron Steven White <aaron.white@rochester.edu>"],
    "license": "MIT",
    "description": "I/O layer for panproto interchange formats",
    "repository": "https://github.com/aaronstevenwhite/panproto",
    "categories": ["encoding", "parser-implementations"],
    "keywords": ["serialization", "protocol", "interchange"]
  },
  "dependencies": {
    "serde": { "version": "1.0", "features": ["derive"] },
    "serde_json": "1.0",
    "thiserror": "2.0",
    "bytes": "1.9"
  },
  "dev-dependencies": {
    "insta": { "version": "1.41", "features": ["json"] },
    "proptest": "1.6"
  },
  "features": {
    "default": ["json"],
    "json": [],
    "full": ["json"]
  }
}
